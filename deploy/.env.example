# ──────────────────────────────────────────────────────────────
# EKA Enterprise-RAG -- Deployment-Konfiguration
# Kopie nach 'deploy/.env' anlegen und anpassen. NIEMALS echte Secrets committen.
# ──────────────────────────────────────────────────────────────

# Lokales LLM (muss per 'ollama pull' geladen werden, s. install-Skript).
OLLAMA_MODEL=qwen2.5:14b

# ── Cloud-Storage (Phase 5, optional) ──
# Auf 'true' setzen, um Dokumente aus einem S3-kompatiblen Bucket zu indexieren.
S3_ENABLED=false
S3_BUCKET=
S3_PREFIX=
# Fuer On-Prem-S3 (MinIO) den Endpoint setzen, dann gehen keine Daten zu AWS:
S3_ENDPOINT_URL=
S3_REGION=
S3_ACL_READER=composite

# S3-Zugangsdaten -- nur lokal in .env, niemals ins Repo/Image:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
